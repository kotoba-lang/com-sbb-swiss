// Sbb_swiss clean-room schema -> Datomic EAVT mapping
// Generated by deepen_actors.py (ADR 260607 deepening phase).

namespace sbb_swiss {

    entity Stop {
        id: string @unique
        code: string
        name: string
        lat: float
        lon: float
        createdAt: datetime
        updatedAt: datetime
    }

    entity Route {
        id: string @unique
        shortName: string
        longName: string
        mode: string
        createdAt: datetime
        updatedAt: datetime
    }

    entity Trip {
        id: string @unique
        routeId: string
        headsign: string
        serviceId: string
        createdAt: datetime
        updatedAt: datetime
    }

    entity Vehicle {
        id: string @unique
        routeId: string
        label: string
        lat: float
        lon: float
        createdAt: datetime
        updatedAt: datetime
    }

    entity ServiceAlert {
        id: string @unique
        routeId: string
        cause: string
        effect: string
        createdAt: datetime
        updatedAt: datetime
    }

    entity Fare {
        id: string @unique
        routeId: string
        price: float
        currency: string
        createdAt: datetime
        updatedAt: datetime
    }

}

    // Auto-injected Cognitive Schema
    entity CognitiveRecord {
        id: string @unique
        originalPayload: string
        aiStatus: string
        aiInsights: json
        computedAt: datetime
    }
